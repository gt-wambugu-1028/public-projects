// devcontainer.json
{
  "name": "Default Dev Container",
  // "dockerComposeFile": "[<Docker Compose file path>]",
  // "service": "",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "shutdownAction": "StopContainer", // StopContainer, StopCompose, None
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14",
      "installTools": true,
      // "toolsToInstall": [""] - To research
      "installJupyterlab": true,
    },
    "ghcr.io/devcontainers/features/rust:1": {
      // "components": ["rustfmt", "clippy"], // To research
    },
    "ghcr.io/devcontainers/features/node:2": {},
    "ghcr.io/devcontainers/features/docker-in-docker:3": {
      "moby": false,
    },
  },
  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh",
  "postStartCommand": "python3 --version",
  // "workspaceFolder": "",
  // "RunArgs": ["--env-file", "<PATH_TO_ENV_FILE>"]
  // "mounts": ["source=,target=,type=,consistency="]
}
